# Copie para .env.openclyp e preencha os valores antes de subir com docker compose

# URL pública da aplicação (ex.: https://seudominio.com)
NEXT_PUBLIC_SITE_URL=https://openclyp.smartiabr.com

# Chave secreta para assinar os cookies de sessão (gere com: openssl rand -hex 32)
SESSION_SECRET=troque_por_uma_string_aleatoria_longa

# Senha de acesso ao workspace (só você vai usar)
ADMIN_PASSWORD=troque_por_uma_senha_forte

# Chave para proteger a API interna (gere com: openssl rand -hex 32)
PIXEL_API_KEY=troque_por_uma_string_aleatoria_longa
