# Copie para .env.openclyp e preencha os valores antes de subir com docker compose

# URL pública da aplicação (ex.: https://seudominio.com)
NEXT_PUBLIC_SITE_URL=https://openclyp.smartiabr.com

# Chave secreta para assinar os cookies de sessão (gere com: openssl rand -hex 32)
SESSION_SECRET=troque_por_uma_string_aleatoria_longa

# Senha de acesso ao workspace (só você vai usar)
ADMIN_PASSWORD=troque_por_uma_senha_forte

# Segredo do Better Auth (gere com: openssl rand -base64 32)
BETTER_AUTH_SECRET=troque_por_uma_string_aleatoria_longa

# Chave para proteger a API interna (gere com: openssl rand -hex 32)
PIXEL_API_KEY=troque_por_uma_string_aleatoria_longa

# Configuração Traefik (não altera o container do Traefik, só roteamento deste app)
TRAEFIK_HOST=openclyp.smartiabr.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_DOCKER_NETWORK=traefik-public

# Opcional: limites de memória para transcrição em CPU
# Modelo padrão quando não informado no request
PIXEL_DEFAULT_WHISPER_MODEL=medium
# Batch padrão usado pelo backend
PIXEL_DEFAULT_BATCH_SIZE=8
# Clamp de batch por runtime
PIXEL_MAX_BATCH_SIZE_CPU=8
PIXEL_MAX_BATCH_SIZE_GPU=32
# Em CPU, rebaixa modelos "large*" para este modelo seguro
PIXEL_FORCE_CPU_SAFE_MODEL=true
PIXEL_CPU_SAFE_MODEL=medium

# Opcional: chunking para áudios longos
PIXEL_TRANSCRIBE_CHUNK_SECONDS=300
PIXEL_TRANSCRIBE_CHUNK_OVERLAP_SECONDS=1.0
